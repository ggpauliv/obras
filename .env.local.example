# ── Gemini API ────────────────────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
REACT_APP_GEMINI_API_KEY=sua-chave-gemini-aqui

# ── API Backend (dev apenas — em prod o nginx faz o proxy) ──────────────────
REACT_APP_API_URL=http://localhost:3001

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere um segredo forte: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-forte-em-producao

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Em desenvolvimento: DB_HOST=localhost  DB_PORT=5433
# Em produção (Docker Compose): DB_HOST=postgres  DB_PORT=5432
DB_HOST=localhost
DB_PORT=5433
DB_NAME=pawliv_obras
DB_USER=pawliv_user
DB_PASSWORD=troque-por-senha-forte-em-producao
